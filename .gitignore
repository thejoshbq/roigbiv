# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg
.eggs/
dist/
build/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.conda/

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Claude IDE (local settings only — project memories stay tracked) ──────────
.claude/settings.local.json

# ── Large data files ──────────────────────────────────────────────────────────
# Raw TIF stacks and all generated/intermediate data products.
# These are too large for git and are regenerable from the pipeline.
data/raw/
data/annotated/
data/scored/
data/union_rois/
data/training/
data/masks/
data/run*/

# ── Suite2p workspace (intermediate outputs, ~11 GB) ─────────────────────────
# Contains .npy stat arrays, .bin binary stacks, .tif masks — all generated.
suite2p_workspace/

# ── Inference outputs (generated by pipeline) ────────────────────────────────
inference/output/
inference/consensus/
inference/traces/

# ── Model training checkpoints (~13 GB, 500+ files at ~26 MB each) ───────────
# Only the deployed model is needed; it is tracked via Git LFS (.gitattributes).
models/checkpoints/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/*.log

# ── Temporary files ───────────────────────────────────────────────────────────
*.tmp
*.temp
tmp/
